# ============================================================
# Rotehügels — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ============================================================


# ------------------------------------------------------------
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ------------------------------------------------------------
# Database — Prisma (required if using HR / payslip module)
# Use the Supabase "Transaction" connection string (port 6543)
# Get from: Supabase → Project Settings → Database → Connection string
# ------------------------------------------------------------

DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true


# ------------------------------------------------------------
# Email / SMTP (required for contact form + supplier notifications)
# Works with any SMTP provider: Gmail, Resend, Postmark, Brevo, etc.
# ------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Sender address shown in outgoing emails
EMAIL_FROM=Rotehügels <noreply@rotehuegels.com>

# Default admin recipient for supplier and contact notifications
EMAIL_TO=sivakumar@rotehuegels.com


# ------------------------------------------------------------
# Site URL (required for server-side fetch calls)
# Use http://localhost:3000 locally, https://www.rotehuegels.com in production
# ------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ------------------------------------------------------------
# Admin access key (required for /admin/suppliers page)
# Set a long random string — e.g. openssl rand -hex 32
# Access the page at /admin/suppliers?key=YOUR_VALUE
# ------------------------------------------------------------

ADMIN_ACCESS_KEY=replace-with-a-long-random-secret
